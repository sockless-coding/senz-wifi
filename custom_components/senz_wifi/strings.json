{
  "config": {
    "step": {
      "user": {
        "title": "Senz WiFi - Enter Credentials",
        "data": {
          "email": "[%key:common::config_flow::data::email%]",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "email": "Email address for your Senz WiFi account",
          "password": "Password for your Senz WiFi account"
        }
      },
      "reauth_confirm": {
        "title": "Senz WiFi - Reauthenticate",
